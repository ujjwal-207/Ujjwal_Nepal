# Cloudflare Configuration Example
# Copy this file to .env.local and fill in your values

# Cloudflare Account ID (found in Cloudflare Dashboard)
NEXT_PUBLIC_CLOUDFLARE_ACCOUNT_ID=your_account_id

# Cloudflare Images Delivery URL (if using Cloudflare Images)
NEXT_PUBLIC_CLOUDFLARE_IMAGES_URL=https://imagedelivery.net/YOUR_ACCOUNT_HASH

# Cloudflare Stream (if using Cloudflare Stream for videos)
NEXT_PUBLIC_CLOUDFLARE_STREAM_DOMAIN=customer-ID.cloudflarestream.com

# Optional: Cloudflare Turnstile (for form protection)
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=your_turnstile_site_key
